{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$CLAUDE_PLUGIN_ROOT/scripts/hook-macos.sh\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\hook-windows.ps1\"",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$CLAUDE_PLUGIN_ROOT/scripts/hook-macos.sh\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\hook-windows.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$CLAUDE_PLUGIN_ROOT/scripts/hook-macos.sh\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\hook-windows.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$CLAUDE_PLUGIN_ROOT/scripts/hook-macos.sh\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\hook-windows.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
